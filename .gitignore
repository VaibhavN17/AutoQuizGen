# ------------------------------
# Workspace-wide ignores
# ------------------------------

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.iml
*.ipr
*.iws

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env/secrets
.env
.env.*
*.local

# ------------------------------
# Frontend
# ------------------------------
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/

# ------------------------------
# Backend
# ------------------------------
backend/target/
backend/build/

# Maven wrapper jar can be re-generated
backend/.mvn/wrapper/maven-wrapper.jar

# Optional Java artifacts
*.class
*.jar
*.war
*.ear

# Temp files
*.tmp
*.temp
